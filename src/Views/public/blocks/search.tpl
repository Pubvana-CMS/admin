<div class="block">
    <div class="block-search">
        <form class="block-search-form" action="{{ action }}" method="GET">
            <label class="block-label" for="block-search-input">{{ label }}</label>
            <input class="block-input" type="search" id="block-search-input" name="q" placeholder="{{ placeholder }}">
            <button class="block-button" type="submit">{{ button_text }}</button>
        </form>
    </div>
</div>
