<div class="pv-block">
    <div class="pv-block-search">
        <form class="pv-block-search-form" action="{{ action }}" method="GET">
            <label class="pv-block-label" for="pv-block-search-input">{{ label }}</label>
            <input class="pv-block-input" type="search" id="pv-block-search-input" name="q" placeholder="{{ placeholder }}">
            <button class="pv-block-button" type="submit">{{ button_text }}</button>
        </form>
    </div>
</div>
