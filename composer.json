{
    "name": "pubvana/admin",
    "description": "Pubvana CMS admin panel",
    "type": "flightphp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "pubvana",
            "email": "cs@pubvana.net"
        }
    ],
    "require": {
        "php": "^8.1",
        "enlivenapp/flight-school": "^0.2",
        "enlivenapp/flight-shield": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "Pubvana\\Admin\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "Pubvana\\Admin\\ComposerScripts::publishAssets"
        ],
        "post-update-cmd": [
            "Pubvana\\Admin\\ComposerScripts::publishAssets"
        ]
    }
}
